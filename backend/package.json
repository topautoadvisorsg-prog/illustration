{
  "name": "@wildlands/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "smoke": "tsx scripts/smoke-test.ts",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "worker:image-generation": "tsx src/workers/image-generation.worker.ts",
    "worker:upscale": "tsx src/workers/upscale.worker.ts",
    "worker:layout": "tsx src/workers/layout.worker.ts",
    "worker:pdf-compile": "tsx src/workers/pdf-compile.worker.ts",
    "worker:epub-export": "tsx src/workers/epub-export.worker.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/node": "^8.40.0",
    "@supabase/supabase-js": "^2.46.1",
    "@wildlands/shared": "*",
    "bullmq": "^5.30.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "epub-gen-memory": "^1.1.2",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.1",
    "openai": "^4.73.0",
    "pagedjs": "^0.4.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "puppeteer-core": "23",
    "react": "18",
    "react-dom": "18",
    "replicate": "^1.0.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "18",
    "@types/react-dom": "18",
    "drizzle-kit": "^0.31.10",
    "epubchecker": "^5.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.6"
  }
}
